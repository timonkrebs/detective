<Window x:Class="Detective.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Detective.Wpf"
        Title="Detective .NET — Forensic Code Analysis" Height="760" Width="1180"
        FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:ScoreToBrushConverter x:Key="ScoreBrush" />
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Repository:" VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBox Grid.Column="1" Text="{Binding RepoPathInput, UpdateSourceTrigger=PropertyChanged}"
                     VerticalAlignment="Center" Padding="4" />
            <Button Grid.Column="2" Content="Analyze" Command="{Binding AnalyzeCommand}"
                    Padding="16,4" Margin="8,0,0,0" />
            <ProgressBar Grid.Column="3" Width="120" Height="16" IsIndeterminate="True" Margin="8,0,0,0"
                         Visibility="{Binding Busy, Converter={StaticResource BoolToVis}}" />
        </Grid>

        <!-- Analyses -->
        <TabControl Grid.Row="1">

            <TabItem Header="Hotspots">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8">
                        <TextBlock Text="Min score:" VerticalAlignment="Center" />
                        <Slider Width="220" Minimum="0" Maximum="500" Margin="8,0"
                                Value="{Binding MinScoreInput}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding MinScoreInput}" VerticalAlignment="Center" Width="40" />
                        <CheckBox Content="Use length metric (LOC) instead of McCabe"
                                  IsChecked="{Binding UseLengthMetric}" VerticalAlignment="Center" Margin="16,0,0,0" />
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding Hotspots.Hotspots}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Score" Binding="{Binding Score}" Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="Foreground"
                                                Value="{Binding Score, Converter={StaticResource ScoreBrush}}" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Commits" Binding="{Binding Commits}" Width="80" />
                            <DataGridTextColumn Header="Complexity" Binding="{Binding Complexity}" Width="90" />
                            <DataGridTextColumn Header="Changed lines" Binding="{Binding ChangedLines}" Width="110" />
                            <DataGridTextColumn Header="File" Binding="{Binding FileName}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="Coupling">
                <DataGrid ItemsSource="{Binding CouplingRows}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Module" Binding="{Binding Module}" Width="*" />
                        <DataGridTextColumn Header="Files" Binding="{Binding FileCount}" Width="100" />
                        <DataGridTextColumn Header="Cohesion %" Binding="{Binding Cohesion}" Width="120" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Change Coupling">
                <DataGrid ItemsSource="{Binding ChangeCouplingPairs}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Times changed together" Binding="{Binding Count}" Width="180">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="Foreground"
                                            Value="{Binding Count, Converter={StaticResource ScoreBrush}, ConverterParameter=30}" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Module A" Binding="{Binding ModuleA}" Width="*" />
                        <DataGridTextColumn Header="Module B" Binding="{Binding ModuleB}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Team Alignment">
                <DockPanel>
                    <CheckBox DockPanel.Dock="Top" Content="Break down by individual user"
                              IsChecked="{Binding ByUserInput}" Margin="8" />
                    <DataGrid ItemsSource="{Binding TeamRows}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Module" Binding="{Binding Module}" Width="*" />
                            <DataGridTextColumn Header="Team / User" Binding="{Binding Team}" Width="220" />
                            <DataGridTextColumn Header="Changed lines" Binding="{Binding Changes}" Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="Code (x-ray)">
                <DataGrid ItemsSource="{Binding Code}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Complexity" Binding="{Binding CyclomaticComplexity}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground"
                                            Value="{Binding CyclomaticComplexity, Converter={StaticResource ScoreBrush}, ConverterParameter=20}" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Lines" Binding="{Binding Lines}" Width="80" />
                        <DataGridTextColumn Header="Methods" Binding="{Binding MethodCount}" Width="90" />
                        <DataGridTextColumn Header="Types" Binding="{Binding TypeCount}" Width="80" />
                        <DataGridTextColumn Header="Max nesting" Binding="{Binding MaxNestingDepth}" Width="100" />
                        <DataGridTextColumn Header="Longest method" Binding="{Binding MaxMethodLength}" Width="120" />
                        <DataGridTextColumn Header="File" Binding="{Binding FilePath}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

        </TabControl>

        <!-- Status -->
        <StatusBar Grid.Row="2" Margin="0,8,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding Status}" />
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding Modules.Count, StringFormat='Modules: {0}'}" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
